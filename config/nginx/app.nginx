server {
    listen 80;
    server_name 104.238.162.40 nationalpoliticalprisonercoalition.org *.nationalpoliticalprisonercoalition.org;
    client_max_body_size 64M;

    root /var/www/NPPC-Website/public;
    index index.php index.html;

    # Gzip is configured at the http level in /etc/nginx/nginx.conf so it
    # applies to every site. JSON + JS + CSS get compressed there.

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;
    }

    location ~ /\.ht {
        deny all;
    }
}
